<?xml version="1.0" encoding="UTF-8"?>
<!--
CCAPIsCredentials.xml Template
Location: <userhome>/xyz-jphil/ccapis/CCAPIsCredentials.xml

This file stores credentials for all CCAPI compatible API providers.
Supports both session-based credentials and OAuth credentials.

REQUIRED FIELDS FOR EACH ACCOUNT:
- id: Unique identifier for this credential (e.g., "MAIN", "ACCOUNT1")
- name: Display name for the account
- email: Email associated with the account
- ccapiBaseUrl: Base URL for the CCAPI service

FOR SESSION-BASED CREDENTIALS:
- orgId: Organization ID from the API provider
- key: Session key/cookie value for authentication

FOR OAUTH CREDENTIALS:
- clientId: OAuth client ID
- clientSecret: OAuth client secret (not shown in this template)

OPTIONAL FIELDS:
- active: Whether this account is active (default: true)
- trackUsage: Whether to track usage for this account (default: false)
- ping: Whether to ping this account (default: false)
- tier: Account tier/priority (default: 1)
- ua: User agent string (optional)
-->
<CCAPIsCredentials>
    <!-- Global Circuit Breaker Configuration (Optional) -->
    <CircuitBreakerConfig
        enabled="true"
        failureThreshold="3"
        rateLimitCooldownMinutes="10"
        genericErrorCooldownMinutes="5"
        halfOpenRetryCount="1"
        recheckUsageBeforeSelectionMinutes="5" />

    <!-- Session-Based Credential Example 1 -->
    <CCAPICredential
        id="ACCOUNT1"
        name="Main Account"
        email="user@example.com"
        ccapiBaseUrl="https://console.anthropic.com"
        orgId="org-12345"
        key="sk-session-key-placeholder-replace-with-actual"
        active="true"
        trackUsage="true"
        ping="true"
        tier="1" />

    <!-- Session-Based Credential Example 2 (disabled) -->
    <CCAPICredential
        id="ACCOUNT2"
        name="Secondary Account"
        email="secondary@example.com"
        ccapiBaseUrl="https://console.anthropic.com"
        orgId="org-67890"
        key="sk-another-session-key-replace-with-actual"
        active="false"
        trackUsage="false"
        ping="false"
        tier="2" />

    <!-- OAuth Credential Example (for future use) -->
    <!--
    <CCAPICredentialOauth
        id="OAUTH1"
        name="OAuth Account"
        email="oauth@example.com"
        clientId="client-id-placeholder"
        ccapiBaseUrl="https://console.anthropic.com"
        ccapiConsoleUrl="https://console.anthropic.com"
        ccapiApiUrl="https://api.anthropic.com"
        active="false"
        trackUsage="false"
        ping="false"
        tier="1" />
    -->
</CCAPIsCredentials>
